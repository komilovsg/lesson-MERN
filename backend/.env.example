PORT=5000

# MongoDB Atlas (Connect → Drivers → Node.js → скопировать connection string)
# Замени <password> на пароль пользователя БД, <database> — имя базы (например lesson-mern)
MONGO_URI=mongodb+srv://<user>:<password>@cluster01.xxxxx.mongodb.net/<database>?retryWrites=true&w=majority

# JWT secret (локально в .env или в config/default.json)
JWT_SECRET=your_jwt_secret_here

# GitHub OAuth (заполняется только локально)
# Настоящие значения укажи в .env, этот файл коммитится без секретов
GITHUB_CLIENT_ID=your_github_client_id_here
GITHUB_CLIENT_SECRET=your_github_client_secret_here
